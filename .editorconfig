root = true

[*]
charset = utf-8
end_of_line = crlf
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_size = 4

# Per standards/dotnet/style.md: file-scoped namespaces required.
csharp_style_namespace_declarations = file_scoped:warning

[*.{xml,csproj,xaml}]
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[Makefile]
indent_style = tab
