<ResourceDictionary
    x:Class="NINA.Plugin.PrometheusExporter.Options"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="Prometheus Exporter_Options">
        <StackPanel Margin="10" Orientation="Vertical">
            <TextBlock Text="Prometheus Exporter" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Port" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox Text="{Binding ExporterOptions.Port, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Bind address" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox Text="{Binding ExporterOptions.BindAddress, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sequence poll interval (seconds)" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox Text="{Binding ExporterOptions.SequencePollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
            </Grid>

            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Autofocus timeout (minutes, 0 = off)" VerticalAlignment="Center" Grid.Column="0"/>
                <TextBox Text="{Binding ExporterOptions.AfTimeoutMinutes, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
            </Grid>

            <TextBlock Text="{Binding ExporterOptions.ServerStatus, StringFormat='Server: {0}'}" Margin="0,10,0,0" FontStyle="Italic"/>
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
